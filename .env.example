# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Agent Security (BẮT BUỘC - Thay đổi trước khi lên Production)
AGENT_SECRET_KEY=citms-agent-secret-key-change-in-production
AGENT_BOOTSTRAP_TOKEN=citms-bootstrap-token-change-in-production

# Database
POSTGRES_SERVER=db
POSTGRES_USER=citms_user
POSTGRES_PASSWORD=citms_password
POSTGRES_DB=citms_db
# DATABASE_URL will be assembled automatically from the above if not provided.
# For Docker, it should be: postgresql+asyncpg://citms_user:citms_password@db:5432/citms_db
DATABASE_URL=postgresql+asyncpg://citms_user:citms_password@db:5432/citms_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Object Storage (MinIO/S3)
MINIO_ROOT_USER=citms_minio_user
MINIO_ROOT_PASSWORD=citms_minio_password
S3_BUCKET_NAME=citms-backups
S3_ENDPOINT=http://minio:9000

# Authentication (BẮT BUỘC - Thay đổi trước khi lên Production)
# Tạo SECRET_KEY mạnh bằng lệnh: openssl rand -hex 32
SECRET_KEY=citms-dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
