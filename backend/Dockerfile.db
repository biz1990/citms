# Sử dụng ảnh Debian thay vì Alpine để cài pg_cron từ PGDG official package
# (Alpine thiếu clang15/llvm15 → build từ source thất bại)
FROM postgres:15

# Cài pg_cron từ PGDG apt repository (đã được cấu hình sẵn trong ảnh postgres:15)
RUN apt-get update \
    && apt-get install -y --no-install-recommends postgresql-15-cron \
    && rm -rf /var/lib/apt/lists/*

# Kích hoạt pg_cron và gắn với database của CITMS
RUN echo "shared_preload_libraries = 'pg_cron'" >> /usr/share/postgresql/postgresql.conf.sample \
    && echo "cron.database_name = 'citms_db'" >> /usr/share/postgresql/postgresql.conf.sample
